# Crypto Project Security Skill -- Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The scripts will auto-load from .env if environment variables are not set.

# ─── Required ─────────────────────────────────────────────────────────
# Etherscan API key (free tier: 5 calls/sec)
# Used by: scripts/onchain-check.sh etherscan
# Get one at: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# ─── Optional ─────────────────────────────────────────────────────────
# Solana RPC URL (defaults to public mainnet-beta if unset)
# Used by: scripts/onchain-check.sh solana-program
# Free options: https://api.mainnet-beta.solana.com (rate-limited)
# Paid options: Helius, QuickNode, Alchemy, etc.
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
